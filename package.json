{
  "name": "illogical-control",
  "version": "1.0.0",
  "description": "Illogical Playground Day 2 — multi-scene realtime control app (Floor Spots + Bomb Timer) with NDI Out for TouchDesigner.",
  "main": "main.js",
  "author": "Illogical Playground",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.illogical.control",
    "productName": "Illogical Control",
    "directories": { "output": "release" },
    "files": [
      "main.js",
      "preload.js",
      "ndi/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/@stagetimerio/grandiose/**"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis"]
    }
  },
  "dependencies": {
    "@stagetimerio/grandiose": "^0.2.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
